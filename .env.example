# ==========================================================================
# PLANTILLA DE SECRETOS  —  copiala a .env y completá los valores reales:
#     cp .env.example .env  &&  nano .env
# ==========================================================================
# El archivo .env real NO se versiona (esta en .gitignore). Este .example si,
# para que al clonar el repo sepas que variables hay que definir.
# --------------------------------------------------------------------------

# --- RomM: base de datos MariaDB ---
# Inventá contraseñas nuevas y fuertes.
ROMM_DB_ROOT_PASSWORD=cambia-esto
ROMM_DB_PASSWORD=cambia-esto

# --- RomM: autenticacion de la app ---
# ROMM_AUTH_SECRET_KEY: cadena larga y aleatoria (ej: openssl rand -hex 32).
ROMM_AUTH_SECRET_KEY=cambia-esto-por-una-cadena-larga-aleatoria
ROMM_AUTH_USERNAME=admin
ROMM_AUTH_PASSWORD=cambia-esto

# --- RomM: metadatos de juegos (APIs externas, opcionales) ---
# IGDB: https://api-docs.igdb.com/#getting-started (via cuenta Twitch dev).
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
# SteamGridDB: https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=
# RetroAchievements: https://retroachievements.org/controlpanel.php
RETROACHIEVEMENTS_API_KEY=

# --- Pi-hole: password del panel web ---
PIHOLE_WEBPASSWORD=cambia-esto
